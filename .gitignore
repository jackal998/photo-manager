# IDE/editor
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Environment files
.env
.env.*
!.env.example

# Local settings — machine-specific paths, not committed
settings.json
settings.local.json
# Exception: qa/settings.json is the QA-isolated config — committed
# intentionally, only references qa/sandbox/ paths, no PII.
!qa/settings.json

# Databases
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.db
*.db-journal
*.db-shm
*.db-wal

# Exceptions: QA fixtures that intentionally test walker skip rules.
# Placed after the Thumbs.db / desktop.ini / *.db rules so the negations
# win the last-match contest.
!qa/sandbox/walker-exclusions/Thumbs.db
!qa/sandbox/walker-exclusions/desktop.ini

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo
testdata/
