# Local settings — machine-specific paths, not committed.
# qa/settings.json is also ignored: qa.scenarios.configure rewrites it
# on every batch run, so committing it created perpetual drift. The
# canonical seed lives at qa/settings.json.example — copy it to
# qa/settings.json on a fresh clone if you want to launch main.py
# directly with PHOTO_MANAGER_HOME=qa. Batch runs (qa.scenarios._batch)
# don't need the seed; configure.py creates settings.json from scratch.
settings.json
settings.local.json

# Claude Code skills — never tracked. Skill files are the kind of
# place a developer might reflex-paste a machine-specific path,
# Synology IP, NAS hostname, or other PII without thinking. Mirror
# the settings.json treatment: each developer's `.claude/skills/`
# lives on disk only. Project-shareable templates (if any are added
# later) should go under a separate `.claude/skills/.example/`
# pattern that's NOT covered by this rule.
.claude/skills/

# Window geometry / splitter state — written by MainWindow.closeEvent on
# every clean exit. Anchored under PHOTO_MANAGER_HOME (or repo root) so
# the QA scenario can isolate from the user's real install; never
# checked in for the same reason settings.json isn't.
window_state.ini

# Databases
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.db
*.db-journal
*.db-shm
*.db-wal

# Exceptions: QA fixtures that intentionally test walker skip rules.
# Placed after the Thumbs.db / desktop.ini / *.db rules so the negations
# win the last-match contest.
!qa/sandbox/walker-exclusions/Thumbs.db
!qa/sandbox/walker-exclusions/desktop.ini

# Runtime-generated disposable fixtures (s13 regenerates the source set
# every run; s16 writes a corrupt sqlite probe). Both intentionally
# disposable — never commit their contents.
qa/sandbox/_disposable/

# Optional symlink fixture for s09. Created by scripts/make_qa_sandbox.py
# when the platform allows (Linux, macOS, Windows with Developer Mode);
# silently skipped otherwise. Must NOT be tracked by Git — Windows clones
# without core.symlinks=true would de-symlink it to a plain text file
# containing the target path, silently breaking the test.
qa/sandbox/walker-exclusions/symlink_to_real.jpg

# qa/sandbox/scoring-mixed/Downloads/ is a fixture for the #187
# scoring system's path-penalty dimension — the subdir is named
# Downloads/ precisely because that's a real "bad path" segment.
# Without this negation, the generic `downloads/` pattern in the
# Python defaults (line 14 above) would silently swallow this
# fixture file and CI would fail with "row not found" for s42.
!qa/sandbox/scoring-mixed/Downloads/

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo
testdata/
