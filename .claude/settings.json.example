{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe scripts/hooks/qa_scenario_guard.py"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe scripts/hooks/docs_guard.py"
          },
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe scripts/hooks/zombie_check.py"
          }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe scripts/hooks/team_task_created.py"
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe scripts/hooks/team_task_completed.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.venv/Scripts/python.exe -m qa.scenarios.*:*)"
    ],
    "ask": [
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(pipx install*)",
      "Bash(uv pip install*)",
      "Bash(uv add*)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(yarn add*)",
      "Bash(pnpm add*)",
      "Bash(pnpm install*)",
      "Bash(git clone*)",
      "Bash(git reset --hard*)",
      "Bash(git reset --hard)",
      "Bash(git rebase*)",
      "Bash(git rebase)",
      "Bash(git commit --amend*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh issue close*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(sudo)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(chmod 777*)",
      "Bash(ssh *)",
      "Bash(* > /dev/*)"
    ],
    "additionalDirectories": [
      "<USER_HOME>/.claude"
    ]
  }
}
